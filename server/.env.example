# Copy this file to `.env` for local server development.
# Do not commit `.env`.

# Required only when AI-backed question generation/rendering is enabled.
OPENAI_API_KEY=

# Defaults are OpenAI-compatible Responses API settings.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CANDIDATE_MODEL=gpt-5.4-mini
OPENAI_RENDER_MODEL=gpt-5.4-mini

# Keep both disabled until the model-backed generator/renderer is wired in.
# The server will continue using deterministic candidate generation/template rendering.
AI_QUESTION_GENERATION_ENABLED=false
AI_QUESTION_RENDERING_ENABLED=false

# Generation retry/batch controls used by the server-side pipeline.
AI_TIMEOUT_SECONDS=30
AI_CANDIDATE_BATCH_MULTIPLIER=2
AI_MAX_GENERATION_ATTEMPTS=3

# Pokémon species lookup. In production this reads the DynamoDB table created
# with pk/sk keys and populated from server/data/curated/pokemon_species_regulation_m_b.jsonl.
AWS_REGION=ap-northeast-2
POKEMON_SPECIES_SOURCE=dynamodb
POKEMON_SPECIES_TABLE_NAME=pokemon-species
POKEMON_OPTIONS_TABLE_NAME=pokemon-options

# User-owned team data. Keep `local` for ephemeral in-memory storage, or set
# `dynamodb` to persist `/api/v1/teams/me` into a pk/sk table.
USER_POKEMON_DATA_SOURCE=local
USER_POKEMON_DATA_TABLE_NAME=user-pokemon-data
USER_POKEMON_DATA_USER_ID=local
